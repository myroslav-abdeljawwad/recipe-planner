# .env.example
#
# Environment configuration for recipe-planner.
# Author: Myroslav Mokhammad Abdeljawwad
#
# Copy this file to .env and adjust the values accordingly.

# Database connection string (SQLite for local dev, Postgres in prod)
DATABASE_URL="sqlite:///./data/recipes.db"

# API key for external ingredient lookup service
INGREDIENTS_API_KEY="YOUR_INGREDIENTS_API_KEY_HERE"

# Default timezone used for scheduling meals
TIMEZONE="UTC"

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL="INFO"

# Number of days to plan ahead
PLAN_DAYS=7

# Enable or disable email notifications
EMAIL_NOTIFICATIONS=false

# SMTP configuration (used only if EMAIL_NOTIFICATIONS=true)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="user@example.com"
SMTP_PASSWORD="password"

# Pantry inventory cache file path
PANTRY_CACHE_PATH="./cache/pantry_cache.json"

# Cache expiration in seconds
CACHE_EXPIRATION_SECONDS=86400

# Feature flag: enable ingredient swap suggestions
ENABLE_SWAP_SUGGESTIONS=true

# Max number of meal options per day
MAX_MEALS_PER_DAY=3

# Path to local data files (ingredients, meals)
DATA_DIR="./data"

# API rate limit settings
API_RATE_LIMIT_PER_MINUTE=60
API_RETRY_DELAY_SECONDS=5

# Health check endpoint URL
HEALTH_CHECK_URL="http://localhost:8000/health"

# Enable debug mode for the CLI
CLI_DEBUG=false